{
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "@/*": ["./src/*"]
      },
      "skipLibCheck": true,
      "checkJs": false,
      "jsx": "react",
      "moduleResolution": "node",
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "noEmit": true
    },
    "include": ["src/**/*"],
    "exclude": [
      "node_modules",
      "dist",
      "build",
      "**/*.spec.ts",
      "**/*.test.ts"
    ],
    "typeAcquisition": {
      "enable": false
    }
  }